NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# AI pipeline sağlayıcısı: "claude" | "gemini" — bkz. src/lib/ai-pipeline/provider.ts.
# Geçici olarak "gemini" kullanılıyor (Anthropic kredi bakiyesi yenilenince "claude"a dönülecek).
AI_PROVIDER=claude
APIFY_TOKEN=
# Scrape maliyet tahmini (opsiyonel): analysis_runs.scrape_cost_usd = fetched_reviews × bu değer.
# compass/google-maps-reviews-scraper pay-per-result birim fiyatı (USD/yorum); boşsa maliyet null loglanır.
APIFY_PRICE_PER_REVIEW_USD=
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
# Cron endpoint koruması: /api/cron/* route'ları "Authorization: Bearer ${CRON_SECRET}" bekler.
# Değeri Vercel proje env'ine de girmeyi unutma — tanımsızsa endpoint fail-closed (500) döner.
CRON_SECRET=
